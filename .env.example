NODE_ENV=development
PORT=3001

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=publichealth_cloud
DB_USER=root
DB_PASSWORD=your_mysql_password

# JWT
JWT_SECRET=change_this_to_a_long_random_string_minimum_32_characters
JWT_EXPIRES_IN=24h

# CORS (frontend URL)
CORS_ORIGIN=http://localhost:5173

# AWS (for production)
AWS_REGION=ap-south-1
AWS_S3_BUCKET=publichealth-surveillance-assets

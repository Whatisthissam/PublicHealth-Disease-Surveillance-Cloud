{
  "name": "publichealth-disease-surveillance-cloud",
  "version": "1.0.0",
  "description": "PublicHealth Disease Surveillance Cloud — AWS Cloud Computing Case Study",
  "scripts": {
    "install:all": "npm --prefix backend install && npm --prefix frontend install",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "build:frontend": "npm --prefix frontend run build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "db:schema": "mysql -u root -p publichealth_cloud < database/schema.sql",
    "db:seed": "mysql -u root -p publichealth_cloud < database/seed.sql"
  },
  "keywords": ["healthcare", "aws", "surveillance", "disease", "public-health"],
  "license": "MIT"
}
